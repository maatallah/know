# Database configuration
# PostgreSQL connection string
DATABASE_URL="postgres://user:password@localhost:5432/know_db"

# NextAuth configuration
# Generate a secret using: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-string-here"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Seed configuration
# Used during the Prisma seed process
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="securepassword123"
